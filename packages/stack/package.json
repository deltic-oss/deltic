{
  "private": true,
  "name": "@deltic/stack",
  "type": "module",
  "version": "2.0.0",
  "description": "Combining the deltic components into a cohesive unit",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "module-sync": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./memory": {
      "import": "./dist/memory.mjs",
      "require": "./dist/memory.cjs",
      "module-sync": "./dist/memory.mjs",
      "types": "./dist/memory.d.mts"
    },
    "./pg": {
      "import": "./dist/pg.mjs",
      "require": "./dist/pg.cjs",
      "module-sync": "./dist/pg.mjs",
      "types": "./dist/pg.d.mts"
    },
    "./rabbitmq": {
      "import": "./dist/rabbitmq.mjs",
      "require": "./dist/rabbitmq.cjs",
      "module-sync": "./dist/rabbitmq.mjs",
      "types": "./dist/rabbitmq.d.mts"
    },
    "./outbox-relay": {
      "import": "./dist/outbox-relay.mjs",
      "require": "./dist/outbox-relay.cjs",
      "module-sync": "./dist/outbox-relay.mjs",
      "types": "./dist/outbox-relay.d.mts"
    }
  },
  "keywords": [
    "event-sourcing",
    "stack",
    "infrastructure",
    "deltic",
    "rabbitmq",
    "outbox"
  ],
  "scripts": {},
  "author": "Frank de Jonge (https://frankdejonge.nl)",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "dependencies": {
    "@deltic/dependency-injection": "workspace:^",
    "@deltic/event-sourcing": "workspace:^",
    "@deltic/messaging": "workspace:^",
    "@deltic/transaction-manager": "workspace:^"
  },
  "peerDependencies": {
    "@deltic/async-pg-pool": "workspace:^",
    "@deltic/dependency-injection": "workspace:^",
    "@deltic/event-sourcing": "workspace:^",
    "@deltic/messaging": "workspace:^",
    "@deltic/mutex": "workspace:^",
    "@deltic/transaction-manager": "workspace:^",
    "amqplib": "^0.10.7",
    "pg": "^8.16.3"
  },
  "peerDependenciesMeta": {
    "@deltic/async-pg-pool": {
      "optional": true
    },
    "@deltic/mutex": {
      "optional": true
    },
    "amqplib": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@deltic/async-pg-pool": "workspace:^",
    "@deltic/mutex": "workspace:^",
    "@types/amqplib": "^0.10.8",
    "@types/pg": "^8.20.0",
    "amqplib": "^1.0.3",
    "pg": "^8.20.0",
    "uuid": "^13.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deltic-oss/deltic.git",
    "directory": "packages/stack"
  }
}

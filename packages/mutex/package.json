  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "crc": "^4.3.2",
    "pg": "^8.20.0"
  },
  "peerDependencies": {
    "crc": "^4.3.2",
    "pg": "^8.16.3"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "crc": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deltic-oss/deltic.git",
    "directory": "packages/mutex"
  }
}
